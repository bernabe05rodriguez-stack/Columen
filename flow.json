{
  "version": "7.1",
  "routing_model": {},
  "screens": [
    {
      "id": "DATOS",
      "title": "Datos de Consulta",
      "terminal": true,
      "success": true,
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "Form",
            "name": "form",
            "children": [
              {
                "type": "TextHeading",
                "text": "Completa tus datos"
              },
              {
                "type": "TextBody",
                "text": "Necesitamos esta informacion para contactarte."
              },
              {
                "type": "TextInput",
                "name": "nombre",
                "label": "Nombre completo",
                "required": true,
                "input-type": "text"
              },
              {
                "type": "TextInput",
                "name": "dni",
                "label": "Numero de DNI",
                "required": true,
                "input-type": "number"
              },
              {
                "type": "TextInput",
                "name": "email",
                "label": "Email",
                "required": true,
                "input-type": "email"
              },
              {
                "type": "TextArea",
                "name": "consulta",
                "label": "Tu consulta",
                "required": true
              },
              {
                "type": "Footer",
                "label": "Enviar",
                "on-click-action": {
                  "name": "complete",
                  "payload": {
                    "nombre": "${form.nombre}",
                    "dni": "${form.dni}",
                    "email": "${form.email}",
                    "consulta": "${form.consulta}"
                  }
                }
              }
            ]
          }
        ]
      }
    }
  ]
}